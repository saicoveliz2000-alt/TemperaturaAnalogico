/* ============================================================
   Sistema de Control de Temperatura Analógico
   Tema: laboratorio de electrónica · gradiente térmico
   ============================================================ */

:root{
  /* superficies */
  --bg:        #080b11;
  --bg-2:      #0c111a;
  --surface:   #111824;
  --surface-2: #16202f;
  --line:      #233044;
  --line-soft: #1a2433;

  /* texto */
  --text:   #e7eef7;
  --muted:  #8a99ad;
  --faint:  #5a6b80;

  /* gradiente térmico (barra de LEDs azul→verde→amarillo→naranja→rojo) */
  --c-blue:   #2f86ff;
  --c-green:  #25d366;
  --c-yellow: #ffd23f;
  --c-orange: #ff8a3d;
  --c-red:    #ff4d4d;

  --thermal: linear-gradient(90deg,
      var(--c-blue) 0%, var(--c-green) 28%,
      var(--c-yellow) 55%, var(--c-orange) 78%, var(--c-red) 100%);

  --accent: var(--c-orange);
  --glow: 0 0 32px -8px var(--c-orange);

  --maxw: 1180px;
  --r: 16px;

  --f-display:'Bricolage Grotesque', sans-serif;
  --f-body:'IBM Plex Sans', sans-serif;
  --f-mono:'IBM Plex Mono', monospace;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;scroll-padding-top:84px}

body{
  font-family:var(--f-body);
  background:var(--bg);
  color:var(--text);
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
  position:relative;
}

/* malla / circuito de fondo */
body::before{
  content:"";
  position:fixed; inset:0; z-index:-2;
  background:
    radial-gradient(900px 600px at 80% -10%, rgba(255,138,61,.10), transparent 60%),
    radial-gradient(800px 600px at 0% 20%, rgba(47,134,255,.08), transparent 55%),
    var(--bg);
}
body::after{
  content:"";
  position:fixed; inset:0; z-index:-1; opacity:.5;
  background-image:
    linear-gradient(var(--line-soft) 1px, transparent 1px),
    linear-gradient(90deg, var(--line-soft) 1px, transparent 1px);
  background-size:46px 46px;
  -webkit-mask-image:radial-gradient(circle at 50% 30%, #000 0%, transparent 75%);
          mask-image:radial-gradient(circle at 50% 30%, #000 0%, transparent 75%);
}

a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}

.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}

/* ---------- tipografía ---------- */
h1,h2,h3,h4{font-family:var(--f-display);font-weight:700;line-height:1.1;letter-spacing:-.02em}
.mono{font-family:var(--f-mono)}

.eyebrow{
  font-family:var(--f-mono);
  font-size:.74rem; letter-spacing:.28em; text-transform:uppercase;
  color:var(--accent); display:inline-flex; align-items:center; gap:10px;
}
.eyebrow::before{content:"";width:26px;height:1px;background:var(--accent);display:inline-block}

/* ============================================================
   NAV
   ============================================================ */
.nav{
  position:fixed; top:0; left:0; right:0; z-index:100;
  backdrop-filter:blur(14px);
  background:rgba(8,11,17,.72);
  border-bottom:1px solid transparent;
  transition:border-color .3s, background .3s;
}
.nav.scrolled{border-bottom-color:var(--line);background:rgba(8,11,17,.9)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px}
.brand{display:flex;align-items:center;gap:11px;font-family:var(--f-display);font-weight:700;font-size:1.02rem}
.brand .dot{
  width:11px;height:11px;border-radius:50%;
  background:var(--thermal);box-shadow:var(--glow);
  animation:pulse 2.6s ease-in-out infinite;
}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.78);opacity:.6}}
.nav-links{display:flex;gap:6px;align-items:center}
.nav-links a{
  font-family:var(--f-mono);font-size:.8rem;color:var(--muted);
  padding:8px 13px;border-radius:8px;transition:.2s;
}
.nav-links a:hover{color:var(--text);background:var(--surface)}
.nav-toggle{display:none;background:none;border:1px solid var(--line);color:var(--text);
  border-radius:8px;padding:7px 10px;cursor:pointer;font-family:var(--f-mono);font-size:.8rem}

/* ============================================================
   HERO
   ============================================================ */
.hero{padding:148px 0 70px;position:relative}
.hero .badges{display:flex;flex-wrap:wrap;gap:8px;margin:22px 0 26px}
.badge{
  font-family:var(--f-mono);font-size:.72rem;color:var(--muted);
  border:1px solid var(--line);border-radius:50px;padding:6px 13px;background:var(--surface);
}
.hero h1{
  font-size:clamp(2.5rem,7vw,5.2rem);margin:8px 0 18px;
}
.hero h1 .grad{
  background:var(--thermal);-webkit-background-clip:text;background-clip:text;color:transparent;
}
.hero p.lead{font-size:clamp(1.02rem,1.6vw,1.22rem);color:var(--muted);max-width:640px}

/* barra LED animada del hero */
.ledbar{display:flex;gap:7px;margin:38px 0 4px}
.ledbar .led{
  flex:1;height:13px;border-radius:4px;background:var(--surface-2);
  border:1px solid var(--line);position:relative;overflow:hidden;
}
.ledbar .led::after{
  content:"";position:absolute;inset:0;opacity:0;transform:translateY(100%);
  transition:transform .5s ease, opacity .5s ease;
}
.ledbar.lit .led::after{opacity:1;transform:translateY(0)}
.ledbar .led:nth-child(-n+4)::after{background:var(--c-blue);box-shadow:0 0 14px var(--c-blue)}
.ledbar .led:nth-child(n+5):nth-child(-n+7)::after{background:var(--c-green);box-shadow:0 0 14px var(--c-green)}
.ledbar .led:nth-child(8)::after,.ledbar .led:nth-child(9)::after{background:var(--c-yellow);box-shadow:0 0 14px var(--c-yellow)}
.ledbar .led:nth-child(10)::after{background:var(--c-red);box-shadow:0 0 16px var(--c-red)}
.ledbar.lit .led:nth-child(1)::after{transition-delay:.05s}
.ledbar.lit .led:nth-child(2)::after{transition-delay:.12s}
.ledbar.lit .led:nth-child(3)::after{transition-delay:.19s}
.ledbar.lit .led:nth-child(4)::after{transition-delay:.26s}
.ledbar.lit .led:nth-child(5)::after{transition-delay:.33s}
.ledbar.lit .led:nth-child(6)::after{transition-delay:.40s}
.ledbar.lit .led:nth-child(7)::after{transition-delay:.47s}
.ledbar.lit .led:nth-child(8)::after{transition-delay:.54s}
.ledbar.lit .led:nth-child(9)::after{transition-delay:.61s}
.ledbar.lit .led:nth-child(10)::after{transition-delay:.68s}
.ledbar-cap{display:flex;justify-content:space-between;font-family:var(--f-mono);font-size:.7rem;color:var(--faint);margin-top:8px}

/* stats */
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;margin-top:54px;
  border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:var(--line)}
.hero-stats .stat{background:var(--surface);padding:22px 20px}
.hero-stats .stat .n{font-family:var(--f-display);font-size:2rem;font-weight:700;line-height:1}
.hero-stats .stat .n.grad{background:var(--thermal);-webkit-background-clip:text;background-clip:text;color:transparent}
.hero-stats .stat .l{font-family:var(--f-mono);font-size:.72rem;color:var(--muted);margin-top:8px;text-transform:uppercase;letter-spacing:.1em}

/* ============================================================
   SECCIONES
   ============================================================ */
section{padding:84px 0;position:relative}
.section-head{max-width:720px;margin-bottom:46px}
.section-head h2{font-size:clamp(1.9rem,4vw,2.9rem);margin:16px 0 14px}
.section-head p{color:var(--muted);font-size:1.04rem}

.phase-tag{
  display:inline-block;font-family:var(--f-mono);font-size:.74rem;letter-spacing:.2em;
  text-transform:uppercase;padding:5px 12px;border-radius:6px;
  background:rgba(255,138,61,.12);color:var(--accent);border:1px solid rgba(255,138,61,.28);
}
.phase-tag.f2{background:rgba(47,134,255,.12);color:var(--c-blue);border-color:rgba(47,134,255,.28)}

/* divisor con etiqueta */
.phase-divider{display:flex;align-items:center;gap:18px;margin:0 0 6px}
.phase-divider .ln{flex:1;height:1px;background:var(--line)}

/* ---------- tarjetas de etapa ---------- */
.stage{
  display:grid;grid-template-columns:1fr 1fr;gap:42px;align-items:center;
  padding:38px 0;border-top:1px solid var(--line-soft);
}
.stage:nth-child(even) .stage-media{order:2}
.stage-media{
  background:#fff;border-radius:var(--r);padding:22px;border:1px solid var(--line);
  position:relative;overflow:hidden;
}
.stage-media img{margin:0 auto}
.stage-media .tag{
  position:absolute;top:12px;left:12px;font-family:var(--f-mono);font-size:.68rem;
  background:#0c111a;color:var(--accent);padding:4px 9px;border-radius:6px;letter-spacing:.08em;
}
.stage-body h3{font-size:1.6rem;margin:14px 0 12px}
.stage-body p{color:var(--muted);margin-bottom:14px}
.stage-step{font-family:var(--f-mono);font-size:.78rem;color:var(--accent);letter-spacing:.2em}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:8px}
.chip{font-family:var(--f-mono);font-size:.73rem;color:var(--text);background:var(--surface-2);
  border:1px solid var(--line);border-radius:6px;padding:5px 10px}
.chip b{color:var(--accent);font-weight:600}

/* ---------- fotos reales ---------- */
.gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.shot{
  background:var(--surface);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;
  transition:transform .3s, border-color .3s, box-shadow .3s;
}
.shot:hover{transform:translateY(-5px);border-color:var(--accent);box-shadow:0 18px 40px -22px var(--accent)}
.shot .ph{aspect-ratio:4/3;overflow:hidden;background:#0c111a}
.shot .ph img{width:100%;height:100%;object-fit:cover}
.shot .cap{padding:16px 18px}
.shot .cap .k{font-family:var(--f-mono);font-size:.72rem;color:var(--accent);letter-spacing:.12em}
.shot .cap h4{font-size:1.05rem;margin:6px 0 6px}
.shot .cap p{font-size:.88rem;color:var(--muted);line-height:1.5}

/* ---------- cálculos ---------- */
.calc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
.calc{
  background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:24px;
  position:relative;
}
.calc::before{content:"";position:absolute;top:0;left:0;width:3px;height:100%;
  background:var(--thermal);border-radius:3px 0 0 3px}
.calc h4{font-size:1.06rem;margin-bottom:10px}
.calc .formula{
  font-family:var(--f-mono);font-size:1.04rem;color:var(--text);background:var(--bg-2);
  border:1px solid var(--line);border-radius:10px;padding:13px 16px;margin:12px 0;letter-spacing:.02em;
}
.calc p{color:var(--muted);font-size:.92rem}

/* ---------- presupuesto ---------- */
.table-wrap{border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:var(--surface)}
table{width:100%;border-collapse:collapse;font-size:.92rem}
thead th{
  font-family:var(--f-mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;
  color:var(--muted);text-align:left;padding:14px 18px;background:var(--bg-2);border-bottom:1px solid var(--line);
}
tbody td{padding:12px 18px;border-bottom:1px solid var(--line-soft)}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover{background:var(--surface-2)}
td.num,th.num{text-align:right;font-family:var(--f-mono)}
.total-row td{font-family:var(--f-display);font-weight:700;font-size:1.05rem;background:var(--bg-2)}
.total-row .grad{background:var(--thermal);-webkit-background-clip:text;background-clip:text;color:transparent}

/* ---------- pros / contras ---------- */
.pc-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.pc{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:26px}
.pc.pro{border-top:3px solid var(--c-green)}
.pc.con{border-top:3px solid var(--c-red)}
.pc h3{font-size:1.25rem;margin-bottom:18px;display:flex;align-items:center;gap:10px}
.pc .ico{width:26px;height:26px;border-radius:7px;display:grid;place-items:center;font-family:var(--f-mono);font-weight:700}
.pc.pro .ico{background:rgba(37,211,102,.15);color:var(--c-green)}
.pc.con .ico{background:rgba(255,77,77,.15);color:var(--c-red)}
.pc ul{list-style:none;display:flex;flex-direction:column;gap:14px}
.pc li{display:flex;gap:12px;font-size:.94rem;color:var(--muted)}
.pc li b{color:var(--text);font-weight:600}
.pc li::before{content:"";flex:0 0 7px;height:7px;border-radius:50%;margin-top:8px}
.pc.pro li::before{background:var(--c-green)}
.pc.con li::before{background:var(--c-red)}

/* ============================================================
   FASE II · RIESGOS
   ============================================================ */
.risk-layout{display:grid;grid-template-columns:1fr 1.35fr;gap:36px;align-items:start}

/* matriz */
.matrix-card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:26px}
.matrix-card h3{font-size:1.2rem;margin-bottom:6px}
.matrix-card .sub{font-family:var(--f-mono);font-size:.76rem;color:var(--muted);margin-bottom:20px}
.matrix{display:grid;grid-template-columns:auto repeat(5,1fr);gap:6px}
.matrix .axis-y{writing-mode:vertical-rl;transform:rotate(180deg);
  font-family:var(--f-mono);font-size:.7rem;color:var(--muted);text-align:center;
  letter-spacing:.18em;text-transform:uppercase;grid-row:1/6;display:grid;place-items:center}
.cell{
  aspect-ratio:1;border-radius:8px;display:grid;place-items:center;position:relative;
  font-family:var(--f-mono);font-weight:700;font-size:.92rem;color:#0a0a0a;cursor:default;
  transition:transform .18s;
}
.cell:hover{transform:scale(1.08);z-index:2}
.cell .ids{position:absolute;font-size:.74rem}
.matrix .xlabels{grid-column:2/7;display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:6px}
.matrix .xlabels span{font-family:var(--f-mono);font-size:.66rem;color:var(--faint);text-align:center}
.axis-x-title{grid-column:2/7;text-align:center;font-family:var(--f-mono);font-size:.7rem;
  letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:8px}

.risk-legend{display:flex;flex-wrap:wrap;gap:14px;margin-top:22px;font-family:var(--f-mono);font-size:.74rem;color:var(--muted)}
.risk-legend .lg{display:flex;align-items:center;gap:7px}
.risk-legend .sw{width:13px;height:13px;border-radius:3px}

/* tabla de riesgos */
.risk-table .table-wrap{overflow-x:auto}
.risk-table table{font-size:.86rem;min-width:560px}
.risk-id{font-family:var(--f-mono);font-weight:700;width:30px;height:30px;border-radius:7px;
  display:grid;place-items:center;color:#0a0a0a}
.pill{font-family:var(--f-mono);font-size:.72rem;padding:4px 9px;border-radius:50px;display:inline-block;font-weight:600}
.pill.score{color:#0a0a0a}
.pill.act{background:var(--surface-2);border:1px solid var(--line);color:var(--text)}
.arrow{color:var(--c-green);font-family:var(--f-mono);font-weight:700}

/* ---------- conclusiones ---------- */
.notes-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.note{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:28px}
.note h3{font-size:1.3rem;margin-bottom:18px;display:flex;align-items:center;gap:12px}
.note h3 .num{font-family:var(--f-mono);font-size:.9rem;color:var(--accent);
  border:1px solid var(--line);border-radius:8px;padding:3px 9px}
.note ol,.note ul{padding-left:20px;display:flex;flex-direction:column;gap:11px}
.note li{color:var(--muted);font-size:.93rem}
.note li::marker{color:var(--accent);font-family:var(--f-mono)}

/* ---------- footer ---------- */
footer{border-top:1px solid var(--line);padding:60px 0 50px;margin-top:40px;background:var(--bg-2)}
.foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px}
footer h4{font-family:var(--f-mono);font-size:.76rem;text-transform:uppercase;letter-spacing:.16em;
  color:var(--accent);margin-bottom:16px}
footer p,footer li{color:var(--muted);font-size:.9rem;line-height:1.7}
footer ul{list-style:none}
.team-list li{display:flex;justify-content:space-between;gap:10px;padding:5px 0;border-bottom:1px dashed var(--line-soft)}
.team-list .carnet{font-family:var(--f-mono);color:var(--faint);font-size:.8rem}
.refs a{color:var(--muted);transition:.2s;border-bottom:1px solid transparent}
.refs a:hover{color:var(--accent);border-bottom-color:var(--accent)}
.foot-bottom{margin-top:46px;padding-top:24px;border-top:1px solid var(--line);
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;
  font-family:var(--f-mono);font-size:.78rem;color:var(--faint)}

/* ---------- reveal ---------- */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
.reveal.in{opacity:1;transform:none}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media(max-width:900px){
  .stage{grid-template-columns:1fr;gap:24px}
  .stage:nth-child(even) .stage-media{order:0}
  .gallery{grid-template-columns:1fr}
  .calc-grid,.pc-grid,.notes-grid{grid-template-columns:1fr}
  .risk-layout{grid-template-columns:1fr}
  .hero-stats{grid-template-columns:1fr 1fr}
  .foot-grid{grid-template-columns:1fr}
  .nav-links{
    position:fixed;top:64px;left:0;right:0;flex-direction:column;align-items:stretch;
    background:rgba(8,11,17,.97);border-bottom:1px solid var(--line);padding:14px;gap:4px;
    transform:translateY(-130%);transition:transform .3s;
  }
  .nav-links.open{transform:none}
  .nav-toggle{display:block}
}
@media(max-width:480px){
  .hero-stats{grid-template-columns:1fr}
  .matrix .axis-y{font-size:.6rem}
}
@media(prefers-reduced-motion:reduce){
  *{animation:none!important;transition:none!important}
  .reveal{opacity:1;transform:none}
}
